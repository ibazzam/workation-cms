# Example environment for local development
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# Auth (JWT bearer tokens)
AUTH_JWT_SECRET=dev-auth-secret
# Default is bearer-only auth; set true temporarily only for local legacy header-based flows
AUTH_ALLOW_HEADER_FALLBACK=false

# Reverse proxy / edge settings (Cloudflare or similar)
# true|false|number|CIDR/function value accepted by Express trust proxy
APP_TRUST_PROXY=true
# Comma-separated origins for CORS; blank means allow all (dev-friendly)
CORS_ORIGIN=

# Domain rollout feature flags
# Global default when per-domain flag is not defined (default true if omitted)
FEATURE_FLAGS_DEFAULT=true
# Per-domain overrides (set false to disable domain routes with HTTP 503)
FEATURE_DOMAIN_WORKATIONS=true
FEATURE_DOMAIN_COUNTRIES=true
FEATURE_DOMAIN_ISLANDS=true
FEATURE_DOMAIN_SERVICE_CATEGORIES=true
FEATURE_DOMAIN_VENDORS=true
FEATURE_DOMAIN_ACCOMMODATIONS=true
FEATURE_DOMAIN_TRANSPORTS=true
FEATURE_DOMAIN_BOOKINGS=true
FEATURE_DOMAIN_PAYMENTS=true
FEATURE_DOMAIN_ADMIN_SETTINGS=true

# Payment providers
# BML Connect base URLs from public docs:
# - UAT: https://api.uat.merchants.bankofmaldives.com.mv
# - PROD: https://api.merchants.bankofmaldives.com.mv
BML_API_BASE_URL=https://api.uat.merchants.bankofmaldives.com.mv
BML_API_KEY=
# Optional override; if omitted, backend uses BML_API_KEY for webhook signature verification
BML_WEBHOOK_SECRET=dev-bml-webhook-secret
BML_CONNECT_LIVE_INTENTS=false
BML_WEBHOOK_URL=
BML_REDIRECT_URL=
# Optional override to force a single currency (otherwise uses per-intent currency)
BML_FORCE_CURRENCY=

# MIB (set once official API docs/credentials are available)
MIB_API_BASE_URL=
MIB_API_KEY=
MIB_WEBHOOK_SECRET=dev-mib-webhook-secret

# MIB legacy hosted-gateway mode (aharen/Pay style)
MIB_LEGACY_MODE=false
MIB_HOST=
MIB_MER_RESP_URL=
MIB_ACQ_ID=
MIB_MER_ID=
MIB_MER_PASSWORD=
# Optional default / override knobs for legacy mode currency mapping
MIB_PURCHASE_CURRENCY=
MIB_FORCE_PURCHASE_CURRENCY=
MIB_PURCHASE_CURRENCY_EXPONENT=2
MIB_VERSION=1
MIB_SIGNATURE_METHOD=SHA1

# Stripe
STRIPE_WEBHOOK_SECRET=dev-webhook-secret

# Automatic reconciliation runner (disabled by default)
PAYMENTS_RECONCILE_ENABLED=false
PAYMENTS_RECONCILE_INTERVAL_MS=300000
PAYMENTS_RECONCILE_INITIAL_DELAY_MS=5000
PAYMENTS_RECONCILE_PROVIDER=
PAYMENTS_RECONCILE_LIMIT=100
PAYMENTS_RECONCILE_DRY_RUN=false
PAYMENTS_RECONCILE_ALERT_STALE_MULTIPLIER=2
PAYMENTS_RECONCILE_ALERT_ERROR_STREAK=3
PAYMENTS_RECONCILE_ALERT_ERRORS_THRESHOLD=5

# Payment background jobs runner
PAYMENTS_JOBS_ENABLED=true
PAYMENTS_JOBS_INTERVAL_MS=10000
PAYMENTS_JOBS_INITIAL_DELAY_MS=3000
PAYMENTS_JOBS_BATCH_SIZE=25
PAYMENTS_JOBS_AUTO_PRUNE_ENABLED=true
PAYMENTS_JOBS_RETENTION_HOURS=168
PAYMENTS_JOBS_PRUNE_LIMIT=200
PAYMENTS_JOBS_ALERT_PENDING_AGE_MS=900000
PAYMENTS_JOBS_ALERT_DEAD_COUNT=5
PAYMENTS_JOBS_ALERT_DEAD_LETTER_RATE=0.2
PAYMENTS_JOBS_ALERT_STALLED_TICK_MS=30000

# Commercial settings are managed via admin API and persisted in DB (AppConfig table)
# GET/POST /api/v1/admin/settings/commercial
