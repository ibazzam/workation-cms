{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "test": "vitest --run",
        "security:secrets": "node scripts/security/secrets-audit.mjs",
        "security:audit": "npm run security:secrets && npm audit --omit=dev && npm --prefix infra/backend audit --omit=dev && composer audit",
        "coverage": "vitest --coverage",
        "e2e": "node tests/e2e/run-e2e.mjs",
        "live:preflight": "node tests/e2e/live-preflight.mjs",
        "cloudflare:staging:preflight": "node tests/e2e/cloudflare-staging-preflight.mjs",
        "perf:booking-payments": "node tests/perf/booking-payments-baseline.mjs",
        "perf:peak-season": "node tests/perf/booking-payments-baseline.mjs",
        "contract:policy": "node scripts/enforce-api-version-policy.mjs",
        "permissions:matrix:write": "node scripts/permission-matrix.mjs --write",
        "permissions:matrix:check": "node scripts/permission-matrix.mjs --check"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@vitest/coverage-v8": "^4.0.18",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "jsdom": "^28.1.0",
        "laravel-vite-plugin": "^2.0.0",
        "prisma": "^4.16.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7",
        "vitest": "^4.0.18"
    },
    "overrides": {
        "minimatch": "^3.1.4",
        "rollup": "^4.59.0"
    },
    "dependencies": {
        "@prisma/client": "^4.16.0",
        "jsonwebtoken": "^9.0.3",
        "yaml": "^2.8.2"
    }
}
