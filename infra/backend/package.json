{
  "name": "workation-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "npx --yes typescript@5.9.3 tsc -p tsconfig.json",
    "prisma:generate": "npx --yes prisma@4.16.0 generate --schema=../prisma/schema.prisma && node scripts/sync-prisma-client.cjs",
    "prisma:migrate": "npx --yes prisma@4.16.0 migrate dev --schema=../prisma/schema.prisma",
    "contract:test": "npm run prisma:generate && npm run build && node scripts/contract-parity.cjs"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@prisma/client": "4.16.0",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "prisma": "^4.16.0",
    "ts-node-dev": "2.0.0",
    "typescript": "5.9.3"
  }
}