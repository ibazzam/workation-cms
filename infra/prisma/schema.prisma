generator client {
  provider = "prisma-client-js"
  output   = "../backend/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// String-backed enums are used for portability across environments

// Core models
model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String?
  password   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  bookings   Booking[]
  reviews    Review[]
  loyaltyAccount LoyaltyAccount?
  loyaltyTransactions LoyaltyTransaction[]
}

model Admin {
  id                BigInt    @id @default(autoincrement())
  name              String
  email             String    @unique(map: "admins_email_unique")
  email_verified_at DateTime?
  password          String
  remember_token    String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  username          String    @unique(map: "admins_username_unique")
  portal_role       String?
  portal_enabled    Boolean   @default(false)
  portal_vendor_id  BigInt?

  @@index([portal_enabled], name: "admins_portal_enabled_index")
  @@index([portal_role], name: "admins_portal_role_index")
  @@index([portal_vendor_id], name: "admins_portal_vendor_id_index")
}

model Vendor {
  id                BigInt    @id @default(autoincrement())
  name              String
  email             String    @unique(map: "vendors_email_unique")
  email_verified_at DateTime?
  password          String
  remember_token    String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  username          String    @unique(map: "vendors_username_unique")
  portal_role       String?
  portal_enabled    Boolean   @default(false)
  portal_vendor_id  BigInt?
  phone             String?

  accommodations Accommodation[]
  transports     Transport[]
  excursions     Excursion[]
  restaurants    Restaurant[]
  resortDayVisits ResortDayVisit[]
  remoteWorkSpaces RemoteWorkspace[]
  vehicleRentals VehicleRental[]
  socialLinks    SocialLink[]
  loyaltyOffers  VendorLoyaltyOffer[]

  @@index([portal_enabled], name: "vendors_portal_enabled_index")
  @@index([portal_role], name: "vendors_portal_role_index")
  @@index([portal_vendor_id], name: "vendors_portal_vendor_id_index")
}

model Atoll {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  islands   Island[]
}

model Island {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  atollId   Int
  lat       Float?
  lng       Float?
  facilitiesSummary     String?
  connectivitySummary   String?
  emergencyServicesInfo String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  atoll     Atoll    @relation(fields: [atollId], references: [id])
  accommodations Accommodation[]
  fromTransports   Transport[] @relation("fromIsland")
  toTransports     Transport[] @relation("toIsland")
  excursions       Excursion[]
  restaurants      Restaurant[]
  resortDayVisits  ResortDayVisit[]
  remoteWorkSpaces RemoteWorkspace[]
  pickupVehicleRentals  VehicleRental[] @relation("rentalPickupIsland")
  dropoffVehicleRentals VehicleRental[] @relation("rentalDropoffIsland")
}

model Accommodation {
  id          String   @id @default(uuid())
    vendorId    BigInt
  islandId    Int
  title       String
  slug        String   @unique
  description String?
  type        String?  
  rooms       Int?     
  minStayNights Int    @default(1)
  price       Decimal  @default("0.00")
  cancellationPolicy String?
  noShowPolicy       String?
  childrenPolicy     String?
  taxesAndFeesPolicy String?
  contentModerationStatus String   @default("APPROVED")
  contentModerationReason String?
  contentModeratedAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  island      Island   @relation(fields: [islandId], references: [id])
  bookings    Booking[]
  blackouts   AccommodationBlackout[]
  seasonalRates AccommodationSeasonalRate[]
  reviews     Review[]
  socialLinks SocialLink[]
}

model AccommodationSeasonalRate {
  id              String   @id @default(uuid())
  accommodationId String
  name            String
  startDate       DateTime
  endDate         DateTime
  nightlyPrice    Decimal  @default("0.00")
  minNights       Int?
  priority        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  accommodation   Accommodation @relation(fields: [accommodationId], references: [id])

  @@index([accommodationId, startDate, endDate])
  @@index([accommodationId, priority])
}

model AccommodationBlackout {
  id              String   @id @default(uuid())
  accommodationId String
  startDate       DateTime
  endDate         DateTime
  reason          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  accommodation   Accommodation @relation(fields: [accommodationId], references: [id])

  @@index([accommodationId, startDate, endDate])
}

model Transport {
  id          String       @id @default(uuid())
  vendorId    BigInt?
  type        String
  code        String?      
  fromIslandId Int?
  toIslandId   Int?
  departure    DateTime?
  arrival      DateTime?
  capacity     Int?
  price        Decimal      @default("0.00")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  vendor       Vendor?      @relation(fields: [vendorId], references: [id])
  fromIsland   Island?      @relation("fromIsland", fields: [fromIslandId], references: [id])
  toIsland     Island?      @relation("toIsland", fields: [toIslandId], references: [id])
  bookings     Booking[]
  fareClasses  TransportFareClass[]
  disruptions  TransportDisruption[] @relation("disruptionPrimaryTransport")
  replacementForDisruptions TransportDisruption[] @relation("disruptionReplacementTransport")
  reviews      Review[]
  socialLinks  SocialLink[]
}

model TransportDisruption {
  id                   String   @id @default(uuid())
  transportId          String
  status               String
  reason               String?
  delayMinutes         Int?
  replacementTransportId String?
  startsAt             DateTime @default(now())
  resolvedAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  transport            Transport @relation("disruptionPrimaryTransport", fields: [transportId], references: [id])
  replacementTransport Transport? @relation("disruptionReplacementTransport", fields: [replacementTransportId], references: [id])

  @@index([transportId, resolvedAt])
  @@index([replacementTransportId])
}

model TransportFareClass {
  id          String    @id @default(uuid())
  transportId String
  code        String
  name        String
  baggageKg   Int?
  seats       Int?
  price       Decimal   @default("0.00")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  transport   Transport @relation(fields: [transportId], references: [id])

  @@unique([transportId, code])
  @@index([transportId])
}

model Excursion {
  id                String   @id @default(uuid())
  vendorId          BigInt
  vendor            Vendor   @relation(fields: [vendorId], references: [id])
  islandId          Int
  type              String
  title             String
  description       String?
  durationMinutes   Int
  baseCapacity      Int      @default(1)
  equipmentRequired Boolean  @default(false)
  equipmentStock    Int      @default(0)
  price             Decimal  @default("0.00")
  // username field removed (was not needed for Excursion)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  island            Island   @relation(fields: [islandId], references: [id])
  slots             ExcursionSlot[]

  @@index([vendorId, active])
  @@index([islandId, active])
  @@index([type, active])
}

model ExcursionSlot {
  id                   String   @id @default(uuid())
  excursionId          String
  startAt              DateTime
  endAt                DateTime
  capacityOverride     Int?
  equipmentStockOverride Int?
  status               String   @default("OPEN")
  note                 String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  excursion            Excursion @relation(fields: [excursionId], references: [id])

  @@index([excursionId, startAt])
  @@index([status, startAt])
}

model Restaurant {
  id                String   @id @default(uuid())
  vendorId          BigInt
  islandId          Int
  name              String
  description       String?
  cuisineType       String
  totalTables       Int      @default(1)
  minPartySize      Int      @default(1)
  maxPartySize      Int      @default(10)
  depositPolicyType String   @default("NONE")
  depositAmount     Decimal  @default("0.00")
  depositCurrency   String   @default("USD")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  vendor            Vendor   @relation(fields: [vendorId], references: [id])
  island            Island   @relation(fields: [islandId], references: [id])
  seatingWindows    RestaurantSeatingWindow[]

  @@index([vendorId, active])
  @@index([islandId, active])
  @@index([cuisineType, active])
}

model RestaurantSeatingWindow {
  id                 String   @id @default(uuid())
  restaurantId       String
  startAt            DateTime
  endAt              DateTime
  tableCountOverride Int?
  minPartySizeOverride Int?
  maxPartySizeOverride Int?
  status             String   @default("OPEN")
  note               String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  restaurant         Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId, startAt])
  @@index([status, startAt])
}

model ResortDayVisit {
  id                 String   @id @default(uuid())
  vendorId           BigInt
  islandId           Int
  title              String
  description        String?
  quotaPerWindow     Int      @default(1)
  includesTransfer   Boolean  @default(false)
  transferMode       String   @default("NONE")
  transferBundlePrice Decimal @default("0.00")
  passRestrictionType String  @default("NONE")
  minAllowedAge      Int      @default(0)
  basePrice          Decimal  @default("0.00")
  currency           String   @default("USD")
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  vendor             Vendor   @relation(fields: [vendorId], references: [id])
  island             Island   @relation(fields: [islandId], references: [id])
  windows            ResortDayVisitWindow[]

  @@index([vendorId, active])
  @@index([islandId, active])
}

model ResortDayVisitWindow {
  id               String   @id @default(uuid())
  resortDayVisitId String
  startAt          DateTime
  endAt            DateTime
  quotaOverride    Int?
  status           String   @default("OPEN")
  note             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  resortDayVisit   ResortDayVisit @relation(fields: [resortDayVisitId], references: [id])

  @@index([resortDayVisitId, startAt])
  @@index([status, startAt])
}

model RemoteWorkspace {
  id                   String   @id @default(uuid())
  vendorId             BigInt
  islandId             Int
  name                 String
  description          String?
  deskInventory        Int      @default(1)
  privateBoothInventory Int     @default(0)
  dayPassPrice         Decimal  @default("0.00")
  weeklyPassPrice      Decimal  @default("0.00")
  currency             String   @default("USD")
  minMbps              Int      @default(10)
  connectivityQuality  String   @default("BASIC")
  hasMeetingRooms      Boolean  @default(false)
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  vendor               Vendor   @relation(fields: [vendorId], references: [id])
  island               Island   @relation(fields: [islandId], references: [id])
  passWindows          RemoteWorkspacePassWindow[]

  @@index([vendorId, active])
  @@index([islandId, active])
  @@index([connectivityQuality, active])
}

model RemoteWorkspacePassWindow {
  id                         String   @id @default(uuid())
  remoteWorkspaceId          String
  startAt                    DateTime
  endAt                      DateTime
  deskInventoryOverride      Int?
  privateBoothInventoryOverride Int?
  status                     String   @default("OPEN")
  note                       String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  remoteWorkspace            RemoteWorkspace @relation(fields: [remoteWorkspaceId], references: [id])

  @@index([remoteWorkspaceId, startAt])
  @@index([status, startAt])
}

model VehicleRental {
  id                    String   @id @default(uuid())
  vendorId              BigInt
  pickupIslandId        Int
  dropoffIslandId       Int?
  vehicleType           String
  title                 String
  description           String?
  inventoryTotal        Int      @default(1)
  minDriverAge          Int      @default(18)
  requiresLicense       Boolean  @default(true)
  acceptedLicenseClasses String?
  allowsDifferentDropoff Boolean @default(false)
  dailyPrice            Decimal  @default("0.00")
  currency              String   @default("USD")
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  vendor                Vendor   @relation(fields: [vendorId], references: [id])
  pickupIsland          Island   @relation("rentalPickupIsland", fields: [pickupIslandId], references: [id])
  dropoffIsland         Island?  @relation("rentalDropoffIsland", fields: [dropoffIslandId], references: [id])
  blackouts             VehicleRentalBlackout[]

  @@index([vendorId, active])
  @@index([pickupIslandId, active])
  @@index([dropoffIslandId, active])
  @@index([vehicleType, active])
}

model VehicleRentalBlackout {
  id              String   @id @default(uuid())
  vehicleRentalId String
  startDate       DateTime
  endDate         DateTime
  unitsBlocked    Int      @default(1)
  reason          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vehicleRental   VehicleRental @relation(fields: [vehicleRentalId], references: [id])

  @@index([vehicleRentalId, startDate, endDate])
}

model Booking {
  id              String        @id @default(uuid())
  userId          String
  accommodationId String? 
  transportId     String?
  transportFareClassCode String?
  startDate       DateTime?
  endDate         DateTime?
  guests          Int?          @default(1)
  totalPrice      Decimal       @default("0.00")
  fareLockUnitPrice  Decimal?
  fareLockTotalPrice Decimal?
  fareLockCurrency   String?
  fareLockExpiresAt  DateTime?
  status          String @default("PENDING")
  holdExpiresAt   DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id])
  accommodation   Accommodation? @relation(fields: [accommodationId], references: [id])
  transport       Transport?    @relation(fields: [transportId], references: [id])
  payment         Payment?
  loyaltyTransactions LoyaltyTransaction[]
}

model Review {
  id              String         @id @default(uuid())
  userId          String
  targetType      String
  accommodationId String?
  transportId     String?
  activityRefId   String?
  serviceRefId    String?
  rating          Int
  title           String?
  comment         String?
  verifiedStay    Boolean        @default(false)
  status          String         @default("PUBLISHED")
  trustSafetyStatus String       @default("CLEAR")
  moderationReasonCode String?
  moderationReviewerNote String?
  flaggedCount    Int            @default(0)
  // username field removed (was not needed for Review)
  escalatedToQueue String?
  escalatedAt     DateTime?
  actionedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user            User           @relation(fields: [userId], references: [id])
  accommodation   Accommodation? @relation(fields: [accommodationId], references: [id])
  transport       Transport?     @relation(fields: [transportId], references: [id])

  @@index([targetType, accommodationId])
  @@index([targetType, transportId])
  @@index([targetType, activityRefId])
  @@index([targetType, serviceRefId])
  @@index([userId, targetType, accommodationId])
  @@index([userId, targetType, activityRefId])
  @@index([userId, targetType, serviceRefId])
  @@index([status, trustSafetyStatus])
}

model SocialLink {
  id                String         @id @default(uuid())
  targetType        String
  accommodationId   String?
  transportId       String?
  vendorId          BigInt?
  platform          String
  url               String
  handle            String?
  embedPolicy       String         @default("LINK_ONLY")
  ugcSafetyStatus   String         @default("SAFE")
  ugcSafetyReason   String?
  trustSafetyStatus String         @default("CLEAR")
  moderationReasonCode String?
  moderationReviewerNote String?
  flaggedCount      Int            @default(0)
  lastFlaggedAt     DateTime?
  escalatedToQueue  String?
  escalatedAt       DateTime?
  actionedAt        DateTime?
  contentQualityStatus String      @default("GOOD")
  contentQualityScore Int          @default(100)
  contentQualityNotes String?
  qualityReviewedAt DateTime?
  verified          Boolean        @default(false)
  displayOrder      Int            @default(0)
  active            Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  accommodation     Accommodation? @relation(fields: [accommodationId], references: [id])
  transport         Transport?     @relation(fields: [transportId], references: [id])
  vendor            Vendor?        @relation(fields: [vendorId], references: [id])

  @@index([targetType, accommodationId, active])
  @@index([targetType, transportId, active])
  @@index([targetType, vendorId, active])
  @@index([targetType, active, verified, ugcSafetyStatus])
  @@index([trustSafetyStatus, contentQualityStatus])
}

model LoyaltyAccount {
  userId            String         @id
  pointsBalance     Int            @default(0)
  lifetimePoints    Int            @default(0)
  tier              String         @default("BRONZE")
  updatedAt         DateTime       @updatedAt

  user              User           @relation(fields: [userId], references: [id])
}

model LoyaltyTransaction {
  id                String         @id @default(uuid())
  userId            String
  bookingId         String?
  type              String
  points            Int
  amount            Decimal?       @default("0.00")
  currency          String?
  description       String?
  createdAt         DateTime       @default(now())

  user              User           @relation(fields: [userId], references: [id])
  booking           Booking?       @relation(fields: [bookingId], references: [id])

  @@index([userId, createdAt])
  @@index([bookingId, type])
}

model VendorLoyaltyOffer {
  id                String         @id @default(uuid())
  vendorId          BigInt
  title             String
  description       String?
  pointsMultiplier  Decimal        @default("1.00")
  discountPercent   Int            @default(0)
  active            Boolean        @default(true)
  startsAt          DateTime?
  endsAt            DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  vendor            Vendor         @relation(fields: [vendorId], references: [id])

  @@index([vendorId, active])
}

model Payment {
  id           String    @id @default(uuid())
  bookingId    String    @unique
  vendorId    BigInt
  providerId   String?   
  amount       Decimal   @default("0.00")
  currency     String    @default("USD")
  status       String    
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  booking      Booking   @relation(fields: [bookingId], references: [id])
}

model PaymentWebhookEvent {
  id        String   @id @default(uuid())
  provider  String
  eventId   String
  eventType String
  payload   Json
  status    String   @default("PROCESSED")
  createdAt DateTime @default(now())

  @@unique([provider, eventId], map: "provider_event_unique")
}

model PaymentReconciliationRun {
  id             String   @id @default(uuid())
  source         String
  providerFilter String   @default("ALL")
  limitUsed      Int
  dryRun         Boolean  @default(false)
  status         String
  scanned        Int      @default(0)
  reconciled     Int      @default(0)
  succeeded      Int      @default(0)
  failed         Int      @default(0)
  unchanged      Int      @default(0)
  skipped        Int      @default(0)
  errors         Int      @default(0)
  errorMessage   String?
  startedAt      DateTime
  finishedAt     DateTime?
  durationMs     Int?
  createdAt      DateTime @default(now())

  @@index([createdAt])
}

model PaymentBackgroundJob {
  id          String   @id @default(uuid())
  type        String
  dedupeKey   String?
  status      String   @default("PENDING")
  attempts    Int      @default(0)
  maxAttempts Int      @default(5)
  runAt       DateTime @default(now())
  payload     Json
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([type, dedupeKey])
  @@index([status, runAt])
  @@index([createdAt])
}

model AppConfig {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminAuditLog {
  id            String   @id @default(uuid())
  actorUserId   String?
  actorRole     String?
  actorEmail    String?
  actorVendorId String?
  vendorId          BigInt
  path          String
  statusCode    Int
  success       Boolean
  requestBody   String?
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@index([actorRole, createdAt])
}

model Country {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceCategory {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  scope     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Workation {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  location    String
  start_date  DateTime
  end_date    DateTime
  price       Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("workations")
}
