{
  "name": "workation-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "npx --yes -p typescript@5.9.3 -p @types/node@20.19.37 -c \"tsc -p tsconfig.json\"",
    "prisma:generate": "npm ci --include=dev --no-audit --fund=false && npx --yes -p prisma@4.16.0 -c \"prisma generate --schema=../prisma/schema.prisma\" && node scripts/sync-prisma-client.cjs",
    "prisma:migrate": "npx --yes -p prisma@4.16.0 -c \"prisma migrate dev --schema=../prisma/schema.prisma\"",
    "contract:test": "npm run prisma:generate && npm run build && node scripts/contract-parity.cjs",
    "render:build": "npm run prisma:generate && npm run build",
    "render:build.": "npm run render:build"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@prisma/client": "4.16.0",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "@types/node": "^20.17.57"
  },
  "devDependencies": {
    "prisma": "^4.16.0",
    "ts-node-dev": "2.0.0",
    "typescript": "5.9.3"
  },
  "overrides": {
    "minimatch": "^3.1.4",
    "multer": "^2.1.1"
  }
}
